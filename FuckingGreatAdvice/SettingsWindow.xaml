<Window x:Class="FuckingGreatAdvice.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource Loc_SettingsWindow_Title}"
        Width="400"
        MinHeight="280"
        MinWidth="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent">
    <!--
      Высота окна: SizeToContent=Height (по контенту, без полосы прокрутки).
      Ширина фиксирована (Width). ResizeMode=NoResize — без ручного растягивания.
    -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Rs.Window.Background}"
            BorderBrush="{DynamicResource Rs.Border}"
            BorderThickness="1">
        <DockPanel>
            <!-- Заголовок -->
            <Border DockPanel.Dock="Top"
                    Height="44"
                    Background="{DynamicResource Rs.Surface}"
                    BorderBrush="{DynamicResource Rs.Border}"
                    BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Padding="14,0,8,0"
                            MouseLeftButtonDown="TitleBar_OnMouseDown">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image x:Name="TitleBarIcon"
                                   Width="30"
                                   Height="30"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="Fant"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Loc_SettingsWindow_Header}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Rs.Text.Primary}"
                                               VerticalAlignment="Center"
                                               Cursor="Hand"
                                               MouseLeftButtonDown="TitleBarAbout_OnMouseLeftButtonDown"/>
                                    <Button Click="TitleBarAbout_OnClick"
                                            Style="{StaticResource Rs.TitleBar.AboutInfo}"/>
                                </StackPanel>
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource Rs.Text.Muted}"
                                           Text="{DynamicResource Loc_SettingsWindow_Subtitle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1"
                            Style="{StaticResource Rs.TitleBar.Close}"
                            Content="&#x00D7;"
                            ToolTip="{DynamicResource Loc_SettingsWindow_CloseWithoutSave}"
                            Click="TitleBarClose_OnClick"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Margin="16,12,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <!-- Язык -->
                    <Border Style="{StaticResource Rs.Settings.Card}">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{DynamicResource Loc_SettingsWindow_LanguageLabel}"
                                   Target="{Binding ElementName=LanguageCombo}"
                                   VerticalAlignment="Center"/>
                            <ComboBox x:Name="LanguageCombo"
                                      Grid.Column="2"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      DisplayMemberPath="NativeName"
                                      SelectedValuePath="Code"
                                      SelectionChanged="LanguageCombo_OnSelectionChanged"/>
                        </Grid>
                    </Border>

                    <!-- Запуск: Windows + совет при старте -->
                    <Border Style="{StaticResource Rs.Settings.Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}" Text="{DynamicResource Loc_SettingsWindow_SectionStartup}"/>
                            <CheckBox x:Name="AutostartCheck"
                                      Margin="0,0,0,4"
                                      Content="{DynamicResource Loc_SettingsWindow_Autostart}"/>
                            <CheckBox x:Name="AdviceOnStartupCheck"
                                      Margin="0,0,0,0"
                                      Content="{DynamicResource Loc_SettingsWindow_AdviceOnStartup}"/>
                        </StackPanel>
                    </Border>

                    <!-- Совет по таймеру -->
                    <Border Style="{StaticResource Rs.Settings.Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Rs.Settings.SectionTitle}"
                                       Text="{DynamicResource Loc_SettingsWindow_SectionAdviceTimer}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="AdviceTimerCheck"
                                          Grid.Column="0"
                                          Margin="0"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          Checked="AdviceTimerCheck_OnIsCheckedChanged"
                                          Unchecked="AdviceTimerCheck_OnIsCheckedChanged"/>
                                <WrapPanel x:Name="AdviceTimerRowPanel"
                                           Grid.Column="1"
                                           VerticalAlignment="Center">
                                    <TextBlock x:Name="AdviceTimerPrefixText"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"
                                               TextWrapping="Wrap"
                                               MouseLeftButtonDown="AdviceTimerCaption_MouseLeftButtonDown"
                                               Text="{DynamicResource Loc_SettingsWindow_AdviceTimerPrefix}"/>
                                    <Border x:Name="AdviceTimerSpinnerBorder"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource Rs.Surface}"
                                            BorderBrush="{DynamicResource Rs.Border}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="32"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="AdviceTimerMinutesText"
                                                     Grid.Column="0"
                                                     MinWidth="32"
                                                     MaxWidth="40"
                                                     MinHeight="22"
                                                     MaxLength="3"
                                                     Padding="2,1"
                                                     FontSize="12"
                                                     VerticalContentAlignment="Center"
                                                     TextAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     PreviewTextInput="AdviceTimerMinutesText_OnPreviewTextInput"
                                                     PreviewKeyDown="AdviceTimerMinutesText_OnPreviewKeyDown"
                                                     LostFocus="AdviceTimerMinutesText_OnLostFocus"/>
                                            <Border Grid.Column="1"
                                                    BorderBrush="{DynamicResource Rs.Border}"
                                                    BorderThickness="1,0,0,0">
                                                <StackPanel Orientation="Vertical">
                                                    <RepeatButton x:Name="AdviceTimerUp"
                                                                  Style="{StaticResource Rs.Settings.NumericSpinnerRepeat}"
                                                                  MinWidth="17"
                                                                  Height="14"
                                                                  Delay="350"
                                                                  Interval="90"
                                                                  Click="AdviceTimerUp_OnClick"
                                                                  BorderThickness="0"
                                                                  FontFamily="pack://application:,,,/Fonts/#Segoe MDL2 Assets"
                                                                  Content="&#xE70E;"
                                                                  FontSize="8"/>
                                                    <Border Height="1"
                                                            Background="{DynamicResource Rs.Border}"
                                                            SnapsToDevicePixels="True"/>
                                                    <RepeatButton x:Name="AdviceTimerDown"
                                                                  Style="{StaticResource Rs.Settings.NumericSpinnerRepeat}"
                                                                  MinWidth="17"
                                                                  Height="14"
                                                                  Delay="350"
                                                                  Interval="90"
                                                                  Click="AdviceTimerDown_OnClick"
                                                                  BorderThickness="0"
                                                                  FontFamily="pack://application:,,,/Fonts/#Segoe MDL2 Assets"
                                                                  Content="&#xE70D;"
                                                                  FontSize="8"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="AdviceTimerSuffixText"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap"
                                               MouseLeftButtonDown="AdviceTimerCaption_MouseLeftButtonDown"
                                               Text="{DynamicResource Loc_SettingsWindow_AdviceTimerSuffix}"/>
                                </WrapPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,0,0,16"
                        Padding="0,16,0,0"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource Rs.Border}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="0,2,12,0">
                            <Hyperlink x:Name="SettingsExitHyperlink"
                                       Style="{StaticResource Rs.Settings.ExitHyperlink}"
                                       Click="SettingsExitHyperlink_OnClick"
                                       ToolTipService.InitialShowDelay="300"
                                       ToolTip="{DynamicResource Loc_SettingsWindow_ExitTooltip}">
                                <InlineUIContainer BaselineAlignment="Center">
                                    <Viewbox Width="11"
                                             Height="11"
                                             Margin="0,0,4,0"
                                             VerticalAlignment="Center">
                                        <Path x:Name="SettingsExitIconPath"
                                              Stretch="Uniform"/>
                                    </Viewbox>
                                </InlineUIContainer>
                                <Run BaselineAlignment="Center"
                                     Text="{DynamicResource Loc_SettingsWindow_ExitLink}"/>
                            </Hyperlink>
                        </TextBlock>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource Rs.Button}"
                                    MinWidth="108"
                                    Margin="0,0,10,0"
                                    Padding="12,8"
                                    Click="Cancel_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE711;"/>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{DynamicResource Loc_SettingsWindow_Cancel}"
                                               Foreground="{DynamicResource Rs.Text.Primary}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource Rs.Button.Accent}"
                                    MinWidth="120"
                                    Padding="12,8"
                                    IsDefault="True"
                                    Click="Save_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Rs.TextBlock.ProfileActionIcon}" Text="&#xE74E;"/>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{DynamicResource Loc_SettingsWindow_Save}"
                                               Foreground="{DynamicResource Rs.Accent}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
